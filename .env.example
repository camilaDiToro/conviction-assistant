# Settings for the Decade AI Challenge backend.
# Copy to .env (gitignored) and fill in as later steps need them.

# APP_NAME=decade-ai-challenge

# Provider config (B4). The CI test suite never hits real providers —
# tests inject StubLLM directly. These vars are only needed for the
# manual smoke script (scripts/smoke_openai.py) and the eventual /chat
# endpoint (B9).
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.5
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_TIMEOUT_SECONDS=60
# Whitelist for per-request /chat model overrides (B10). The /chat
# handler rejects any model not in this list with a 400. Default keeps
# the current gpt-5 family + gpt-4.1 (non-reasoning); widen as needed.
# ALLOWED_MODELS=["gpt-5.5","gpt-5.4-mini","gpt-5.1","gpt-5","gpt-5-mini","gpt-4.1"]

# Agent loop tuning (B7). Read by app/agent/loop.py and app/agent/rewrite.py.
# All values shown are defaults; uncomment to override per-environment
# without code changes.
# AGENT_MAX_TOOL_CALLS=5            # strict upper bound; the (N+1)th call is rejected
# AGENT_MAX_ITERATIONS=12           # safety cap; raises AgentError if exceeded
# AGENT_MAX_OUTPUT_TOKENS=8192      # per-turn output budget for the agent loop
# AGENT_REASONING_EFFORT=medium     # gpt-5 family: none|minimal|low|medium|high|xhigh
# REWRITE_MAX_OUTPUT_TOKENS=200     # rewrite stage emits one question; 200 is plenty
# REWRITE_REASONING_EFFORT=minimal  # rewrite is a tiny task

# Verifier (B8). Read by app/agent/loop.py.
# VERIFIER_ENABLED=true             # disable only for tests / debugging
# VERIFIER_RETRY_BUDGET=1           # one retry-with-feedback before strip; ROADMAP B8 pins this

# Strategy seams. Single-member Literal today; widening = add a new
# strategy file under app/retrieval/ or app/agent/verifier/, decorate
# with @register('name'), then widen the Literal in app/config/settings.py.
# The substring verifier is the architectural commitment — alternatives
# require a deliberate code change, not a .env flip.
# RETRIEVAL_STRATEGY=bm25           # one of: bm25
# VERIFIER_STRATEGY=substring       # one of: substring

# B9 access tokens. The chat token is what the user pastes into the
# frontend gate (sent on every /chat request as X-Chat-Token). The admin
# token guards /admin/* (sent as X-Admin-Token, never exposed to the
# browser). Both are required in production; pick long random strings.
# Tests override the auth deps directly and don't read these.
# CHAT_ACCESS_TOKEN=replace-me-with-a-long-random-string
# ADMIN_TOKEN=replace-me-with-a-different-long-random-string

# Deploy. Auto-runs ingest_corpus on startup if the passages table is empty.
# Default false (local dev / tests). Set true on Hugging Face Spaces' free
# tier where the filesystem is ephemeral and the DB is wiped on every cold
# start. The Dockerfile sets this to true so HF deploys work out of the box.
# AUTO_INGEST_ON_STARTUP=false
