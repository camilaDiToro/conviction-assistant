# Settings for the Decade AI Challenge backend.
# Copy to .env (gitignored) and fill in as needed.

# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.5
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_TIMEOUT_SECONDS=60

# Agent loop tuning. Read by app/agent/loop.py and app/agent/rewrite.py.
# All values shown are defaults; uncomment to tune per environment
# without code changes.
# AGENT_MAX_TOOL_CALLS=5            # strict upper bound; the (N+1)th call is rejected
# AGENT_MAX_ITERATIONS=12           # safety cap; raises AgentError if exceeded
# AGENT_MAX_OUTPUT_TOKENS=8192      # per-turn output budget for the agent loop
# AGENT_REASONING_EFFORT=low        # gpt-5 family: none|minimal|low|medium|high|xhigh
# REWRITE_MAX_OUTPUT_TOKENS=200     # rewrite stage emits one question; 200 is plenty
# REWRITE_REASONING_EFFORT=low      # rewrite is a tiny task

# Retrieval strategy seam. Single-member Literal today; widening = add a
# new strategy file under app/retrieval/, decorate with @register('name'),
# then widen the Literal in app/config/settings.py. Alternatives require
# a deliberate code change, not a .env flip.
# RETRIEVAL_STRATEGY=bm25           # one of: bm25

# Access tokens. The chat token is what the user pastes into the
# frontend gate (sent on every /chat request as X-Chat-Token). The admin
# token guards /admin/* (sent as X-Admin-Token, never exposed to the
# browser). Both are required in production; pick long random strings.
# Tests patch the auth deps directly and don't read these.
# CHAT_ACCESS_TOKEN=replace-me-with-a-long-random-string
# ADMIN_TOKEN=replace-me-with-a-different-long-random-string

# Deploy. Auto-runs ingest_corpus on startup if the passages table is empty.
# Default false (local dev / tests). Set true on Hugging Face Spaces' free
# tier where the filesystem is ephemeral and the DB is wiped on every cold
# start. The Dockerfile sets this to true so HF deploys work out of the box.
# AUTO_INGEST_ON_STARTUP=false
