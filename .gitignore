# Environment
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Frontend (Vite + React)
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Local data — Postgres in docker compose, OpenAI vector caches, etc.
# Anchored to repo root so frontend/src/data/ (TS data modules) is NOT ignored.
/data/
postgres-data/

# Editor / OS / agent harness
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
.claude/
.playwright-mcp/

# Logs
*.log
logs/

# Eval run artifacts (per-run timestamped CSV/JSON/MD/JSONL).
# Each numbered subdir (0001, 0002, …) groups runs taken under the same
# code/prompt baseline; the CHANGES.md inside explains what shifted vs
# the previous group, so it IS tracked (data files stay ignored).
evals/results/*
!evals/results/*/
evals/results/*/*
!evals/results/*/CHANGES.md
